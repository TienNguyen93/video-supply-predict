# ============================================================
# Environment variables reference — copy to .env and fill in
# ============================================================

# --- App ---
APP_ENV=development        # development | staging | production
LOG_LEVEL=INFO

# --- DuckDB ---
DUCKDB_PATH=./data/warehouse.duckdb

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=demand-signal-quantile
MLFLOW_MODEL_NAME=demand-lift-lgbm

# --- Groq (required for LangGraph investigation + action agents) ---
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Slack (optional — alerts appear in Streamlit queue without it) ---
# Create an incoming webhook at: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# --- Streamlit ---
STREAMLIT_API_BASE_URL=http://fastapi:8000
DASHBOARD_REFRESH_INTERVAL_S=60

# --- Synthetic Data ---
NUM_SKUS=50
NUM_VIDEOS=200
SNAPSHOT_HOURS=48
RANDOM_SEED=42

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_in_production
AIRFLOW_UID=50000

# --- Postgres (used by Airflow in production mode) ---
# POSTGRES_USER=airflow
# POSTGRES_PASSWORD=airflow
# POSTGRES_DB=airflow
